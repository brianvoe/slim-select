{
  "name": "slim-select",
  "description": "Slim advanced select dropdown",
  "version": "3.5.0",
  "type": "module",
  "author": "Brian Voelker <brian@webiswhatido.com> (http://webiswhatido.com)",
  "homepage": "https://slimselectjs.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brianvoe/slim-select.git"
  },
  "bugs": {
    "url": "https://github.com/brianvoe/slim-select/issues"
  },
  "keywords": [
    "select",
    "vanilla",
    "dropdown",
    "search",
    "multiselect"
  ],
  "main": "dist/slimselect.js",
  "browser": "dist/slimselect.js",
  "module": "dist/slimselect.es.js",
  "unpkg": "dist/slimselect.js",
  "types": "dist/index.d.ts",
  "style": "dist/slimselect.css",
  "sass": "src/slim-select/slimselect.scss",
  "files": [
    "dist",
    "src/slim-select/slimselect.scss"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/slimselect.es.js",
      "require": "./dist/slimselect.cjs.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js",
      "require": "./dist/vue/index.umd.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.umd.js"
    },
    "./styles": "./dist/slimselect.css",
    "./scss": "./src/slim-select/slimselect.scss"
  },
  "scripts": {
    "dev": "vite --config vite.config.docs.mts",
    "format": "prettier --write --cache \"src/**/*.{ts,tsx,vue,scss,json}\"",
    "build": "npm run typecheck && npm run build:clean && npm run build:library && npm run build:docs",
    "build:clean": "rimraf ./dist/* && rimraf ./docs/*",
    "build:docs": "npm run generate:sitemap && vite build --config vite.config.docs.mts",
    "build:library": "npm run build:library:js && npm run build:library:vue && npm run build:library:react && npm run build:library:css",
    "build:library:js": "npm run build:es-cjs && npm run build:umd-iife",
    "build:es-cjs": "vite build --config vite.config.lib.es-cjs.ts",
    "build:umd-iife": "vite build --config vite.config.lib.umd-iife.ts",
    "build:library:vue": "vite build --config vite.config.vue.mts",
    "build:library:react": "vite build --config vite.config.react.mts",
    "build:library:css": "sass src/slim-select/slimselect.scss dist/slimselect.css --style=compressed",
    "lint": "prettier --check \"src/**/*.{ts,tsx,vue,scss,json}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate:sitemap": "node sitemap.js",
    "release": "node release.js"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/downloadjs": "^1.4.6",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.10",
    "axe-core": "^4.12.0",
    "downloadjs": "^1.4.7",
    "highlight.js": "^11.0.0",
    "jsdom": "^29.1.1",
    "pinia": "^3.0.4",
    "prettier": "^3.8.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.3",
    "sass": "^1.100.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  }
}
